#!/usr/bin/env python3
# SPDX-License-Identifier: GPL-3.0-or-later
# copilot-gtk launcher script (configured by Meson)

import os
import sys
import signal
import locale
import gettext

VERSION = '@VERSION@'
pkgdatadir = '@pkgdatadir@'
localedir = '@localedir@'

sys.path.insert(1, pkgdatadir)
signal.signal(signal.SIGINT, signal.SIG_DFL)

locale.bindtextdomain('copilot-gtk', localedir)
locale.textdomain('copilot-gtk')
gettext.install('copilot-gtk', localedir)

if __name__ == '__main__':
    from copilot_gtk.main import main
    sys.exit(main())
