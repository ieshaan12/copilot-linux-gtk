{
    "app-id": "io.github.ieshaan.CopilotGTK",
    "runtime": "org.gnome.Platform",
    "runtime-version": "47",
    "sdk": "org.gnome.Sdk",
    "command": "copilot-gtk",
    "finish-args": [
        "--share=ipc",
        "--socket=fallback-x11",
        "--socket=wayland",
        "--share=network",
        "--device=dri",
        "--talk-name=org.freedesktop.secrets"
    ],
    "cleanup": [
        "/include",
        "/lib/pkgconfig",
        "/man",
        "/share/doc",
        "/share/man",
        "/share/pkgconfig",
        "*.la",
        "*.a"
    ],
    "modules": [
        {
            "name": "python-dependencies",
            "buildsystem": "simple",
            "build-commands": [
                "pip3 install --no-index --find-links=\"${PWD}/pip-packages\" --prefix=${FLATPAK_DEST} --no-build-isolation github-copilot-sdk PyGObject pycairo gbulb mistune"
            ],
            "sources": [
                {
                    "type": "file",
                    "url": "https://files.pythonhosted.org/packages/source/g/github-copilot-sdk/github_copilot_sdk-0.1.29.tar.gz",
                    "sha256": "",
                    "dest": "pip-packages"
                }
            ]
        },
        {
            "name": "copilot-gtk",
            "buildsystem": "meson",
            "sources": [
                {
                    "type": "dir",
                    "path": "."
                }
            ]
        }
    ]
}
